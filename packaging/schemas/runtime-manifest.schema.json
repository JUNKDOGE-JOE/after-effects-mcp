{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "platform",
    "node",
    "python",
    "licenseApprovals",
    "components",
    "files"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "platform": { "enum": ["macos-arm64", "windows-x64"] },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "assetSha256"],
      "properties": {
        "version": { "const": "24.17.0" },
        "assetSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "python": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "distributionRelease", "assetSha256"],
      "properties": {
        "version": { "const": "3.13.14" },
        "distributionRelease": { "const": "20260610" },
        "assetSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "licenseApprovals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package", "version", "sourceSha256", "licenseRef", "approvalId"],
        "properties": {
          "package": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "sourceSha256": { "$ref": "#/$defs/sha256" },
          "licenseRef": { "type": "string", "pattern": "^LicenseRef-" },
          "approvalId": { "type": "string", "minLength": 1 }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "license", "source", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "license": {
            "type": "string",
            "minLength": 1,
            "not": { "const": "UNKNOWN" }
          },
          "source": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size", "mode", "type"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "size": { "type": "integer", "minimum": 0 },
          "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
          "type": { "enum": ["file", "symlink"] }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

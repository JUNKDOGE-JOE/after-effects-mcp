{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeLicenseInventoryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "platform",
    "components",
    "licenseApprovals",
    "extractedLicenses"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "platform": { "enum": ["macos-arm64", "windows-x64"] },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    },
    "licenseApprovals": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval" }
    },
    "extractedLicenses": {
      "type": "array",
      "items": { "$ref": "#/$defs/extractedLicense" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": { "enum": ["metadata-file", "source-file", "payload-file"] },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "license", "source", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "relationship": { "enum": ["STATIC_LINK", "DYNAMIC_LINK", "CONTAINS"] },
        "disposition": { "const": "payload" },
        "licenseEvidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "sourceSha256", "licenseRef", "approvalId"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sourceSha256": { "$ref": "#/$defs/sha256" },
        "licenseRef": { "type": "string", "pattern": "^LicenseRef-" },
        "approvalId": { "type": "string", "minLength": 1 }
      }
    },
    "extractedLicense": {
      "type": "object",
      "additionalProperties": false,
      "required": ["licenseId", "name", "extractedText", "evidence"],
      "properties": {
        "licenseId": {
          "type": "string",
          "pattern": "^LicenseRef-[A-Za-z0-9.-]+$"
        },
        "name": { "type": "string", "minLength": 1 },
        "extractedText": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    }
  }
}

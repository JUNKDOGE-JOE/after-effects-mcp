{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PythonStandaloneBomV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pythonVersion", "distributionRelease", "releaseCommit", "platforms"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "pythonVersion": { "type": "string", "minLength": 1 },
    "distributionRelease": { "type": "string", "minLength": 1 },
    "releaseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macos-arm64", "windows-x64"],
      "properties": {
        "macos-arm64": { "$ref": "#/$defs/platform" },
        "windows-x64": { "$ref": "#/$defs/platform" }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadataSource", "externalSystemDependenciesScope", "externalSystemDependencies", "components"],
      "properties": {
        "metadataSource": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "sha256", "size", "expandedTarBytes", "expandedTarSha256", "targetTriple", "buildOptions", "pythonJson"],
          "properties": {
            "url": { "type": "string", "pattern": "^https://" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "size": { "type": "integer", "minimum": 1 },
            "expandedTarBytes": { "type": "integer", "minimum": 1, "maximum": 536870912 },
            "expandedTarSha256": { "$ref": "#/$defs/sha256" },
            "targetTriple": { "type": "string", "minLength": 1 },
            "buildOptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "pythonJson": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "const": "python/PYTHON.json" },
                "sha256": { "$ref": "#/$defs/sha256" }
              }
            }
          }
        },
        "externalSystemDependenciesScope": {
          "enum": [
            "locked-payload-native-imports-excluding-baseline-loader-libraries",
            "PYTHON.json-declared-system-links-excluding-placeholders-and-baseline-loader-libraries"
          ]
        },
        "externalSystemDependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component" }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "relationship", "disposition", "licenseDeclared", "source", "evidenceOrigins", "licenseEvidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "relationship": { "enum": ["STATIC_LINK", "DYNAMIC_LINK", "CONTAINS"] },
        "disposition": { "const": "payload" },
        "licenseDeclared": { "type": "string", "minLength": 1, "not": { "const": "UNKNOWN" } },
        "source": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "url", "sha256"],
              "properties": {
                "kind": { "const": "archive" },
                "url": { "type": "string", "pattern": "^https://" },
                "sha256": { "$ref": "#/$defs/sha256" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "path", "sha256"],
              "properties": {
                "kind": { "const": "runtime-file" },
                "path": { "type": "string", "pattern": "^python/" },
                "sha256": { "$ref": "#/$defs/sha256" }
              }
            }
          ]
        },
        "evidenceOrigins": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceOrigin" }
        },
        "licenseEvidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/licenseEvidence" }
        },
        "payloadEvidence": { "$ref": "#/$defs/payloadEvidence" }
      }
    },
    "evidenceOrigin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "licenseEvidence": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "sha256"],
          "properties": {
            "kind": { "enum": ["metadata-file", "source-file", "payload-file"] },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "archiveSha256", "memberSha256"],
          "properties": {
            "kind": { "const": "source-archive-member" },
            "path": { "type": "string", "minLength": 1, "not": { "pattern": "^/" } },
            "archiveSha256": { "$ref": "#/$defs/sha256" },
            "memberSha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    },
    "payloadEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pkgIndex", "subtreeManifest"],
      "properties": {
        "pkgIndex": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "size", "sha256"],
          "properties": {
            "path": { "type": "string", "pattern": "^python/" },
            "size": { "type": "integer", "minimum": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "subtreeManifest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "entryCount", "algorithm", "sha256"],
          "properties": {
            "path": { "type": "string", "pattern": "^python/" },
            "entryCount": { "type": "integer", "minimum": 1 },
            "algorithm": { "const": "c-byte-sort-path-tab-size-tab-sha256-lf-v1" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    }
  }
}

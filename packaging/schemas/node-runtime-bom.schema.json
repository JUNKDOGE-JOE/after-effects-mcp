{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NodeRuntimeBomV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "nodeVersion",
    "sourceAsset",
    "platforms",
    "licenseNotices",
    "payloadComponents",
    "excludedLicenseSections"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "nodeVersion": { "type": "string", "minLength": 1 },
    "sourceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256", "license"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "const": "LICENSE" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macos-arm64", "windows-x64"],
      "properties": {
        "macos-arm64": { "$ref": "#/$defs/platform" },
        "windows-x64": { "$ref": "#/$defs/platform" }
      }
    },
    "licenseNotices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/licenseNotice" }
    },
    "payloadComponents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    },
    "excludedLicenseSections": {
      "type": "array",
      "items": { "$ref": "#/$defs/excluded" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "licenseNotice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "tarball", "archivePath", "sourcePath", "payloadPath", "sha256"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "tarball": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "integrity", "sha256", "bytes"],
          "properties": {
            "url": { "type": "string", "pattern": "^https://registry\\.npmjs\\.org/" },
            "integrity": { "type": "string", "pattern": "^sha512-[A-Za-z0-9+/]+={0,2}$" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "bytes": { "type": "integer", "minimum": 1 }
          }
        },
        "archivePath": { "type": "string", "pattern": "^package/LICENSE(?:\\.md)?$" },
        "sourcePath": { "type": "string", "pattern": "^packaging/licenses/node-runtime/[A-Za-z0-9._-]+$" },
        "payloadPath": { "type": "string", "pattern": "^licenses/node-runtime/[A-Za-z0-9._-]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["licenseFile", "processVersions", "verification"],
      "properties": {
        "licenseFile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "const": "node/LICENSE" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "processVersions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        },
        "verification": { "enum": ["verified-native", "pending-native"] }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "relationship",
        "disposition",
        "licenseDeclared",
        "sourceSubpath",
        "licenseEvidence"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "relationship": { "enum": ["STATIC_LINK", "CONTAINS"] },
        "disposition": { "const": "payload" },
        "licenseDeclared": { "type": "string", "minLength": 1, "not": { "const": "UNKNOWN" } },
        "sourceSubpath": { "type": "string", "minLength": 1 },
        "processVersionKey": { "type": "string", "minLength": 1 },
        "licenseEvidence": {
          "oneOf": [
            { "$ref": "#/$defs/evidence" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/evidence" }
            }
          ]
        }
      }
    },
    "evidence": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "license-preamble" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "heading", "sourceSubpath"],
          "properties": {
            "kind": { "const": "license-section" },
            "heading": { "type": "string", "minLength": 1 },
            "sourceSubpath": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "sha256"],
          "properties": {
            "kind": { "const": "source-file" },
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "sha256"],
          "properties": {
            "kind": { "const": "payload-file" },
            "path": { "type": "string", "pattern": "^licenses/node-runtime/[A-Za-z0-9._-]+$" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    },
    "excluded": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "sourceSubpath", "disposition", "reason"],
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "sourceSubpath": { "type": "string", "minLength": 1 },
        "disposition": { "enum": ["pruned", "build-only", "disabled"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}

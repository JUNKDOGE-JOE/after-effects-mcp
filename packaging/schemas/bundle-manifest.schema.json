{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BundleManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "version",
    "platform",
    "sourceCommitSha",
    "runtime",
    "helper",
    "files"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "platform": { "enum": ["macos-arm64", "windows-x64"] },
    "sourceCommitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeVersion",
        "pythonVersion",
        "manifestSha256",
        "sbomSha256",
        "licenseInventorySha256"
      ],
      "properties": {
        "nodeVersion": { "const": "24.17.0" },
        "pythonVersion": { "const": "3.13.14" },
        "manifestSha256": { "$ref": "#/$defs/sha256" },
        "sbomSha256": { "$ref": "#/$defs/sha256" },
        "licenseInventorySha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["helperId", "manifestSha256"],
      "properties": {
        "helperId": { "const": "com.junkdoge.ae-mcp.platform-helper" },
        "manifestSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/file" },
          { "$ref": "#/$defs/symlink" }
        ]
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "baseEntry": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 },
        "mode": { "type": "string", "pattern": "^[0-7]{4}$" }
      },
      "required": ["path", "sha256", "size", "mode"]
    },
    "file": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "size", "mode", "type"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" },
            "size": { "type": "integer", "minimum": 0 },
            "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
            "type": { "const": "file" }
          }
        }
      ]
    },
    "symlink": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "size", "mode", "type", "linkTarget"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" },
            "size": { "type": "integer", "minimum": 0 },
            "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
            "type": { "const": "symlink" },
            "linkTarget": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
